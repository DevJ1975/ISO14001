MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=iso14001_auditor
PORT=4300
CORS_ORIGIN=http://127.0.0.1:4200

# Secret used to sign/verify session JWTs. Generate a strong random value for
# any shared or production environment, e.g. `openssl rand -hex 32`.
JWT_SECRET=
# Session token lifetime in seconds (default 12h).
JWT_TTL_SECONDS=43200

# Password seeded for the demo auditor by `npm run mongo:init`.
DEMO_AUDITOR_PASSWORD=audit-demo-2026

# Local development convenience ONLY: trust x-iso-* identity headers instead of
# a verified JWT. Leave false; production authenticates with bearer tokens.
ALLOW_DEV_AUTH_HEADERS=false

# --- Platform superadmin + client onboarding ---
# Public app origin used to build the "set your password" link in invite emails.
APP_PUBLIC_URL=http://127.0.0.1:4200
# Email seam: 'logging' (default) writes invites to the server log; 'smtp'/'resend'
# are seams for a real provider (not yet wired). EMAIL_FROM is the sender address.
EMAIL_PROVIDER=logging
EMAIL_FROM=no-reply@iso-audit.local
# How long a single-use set-password link stays valid, in seconds (default 72h).
SET_PASSWORD_TTL_SECONDS=259200
# Return the raw set-password link in API responses (handy for local/dev with the
# logging mailer). MUST be false in production so links never leak through the API.
EXPOSE_SET_PASSWORD_LINK=false
# Optional first-superadmin bootstrap, seeded by `npm run mongo:init` when BOTH
# are set. Sign in at /admin/login to provision clients, auditors and client users.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# --- Enterprise auth (TOTP MFA, SSO, SCIM) — all optional, default OFF ---
# TOTP MFA needs no config: members opt in per-account from the Users screen; the
# secret is generated server-side and stored on the member (never logged).
#
# SSO (OIDC): config is stored PER TENANT in the database (issuer/clientId/etc.)
# via the admin UI — no provider details belong here. SSO_CALLBACK_BASE_URL is the
# public app origin the IdP redirects back to (the callback path is appended);
# defaults to APP_PUBLIC_URL. The OIDC initiate/redirect is real; the live IdP
# token exchange is gated by SSO_LIVE_EXCHANGE (keep false until a real provider
# is wired). When enabling it, supply the per-tenant OIDC client secret via env
# (never commit it) — e.g. SSO_CLIENT_SECRET_<TENANTID> read by your deployment.
SSO_CALLBACK_BASE_URL=http://127.0.0.1:4200
SSO_LIVE_EXCHANGE=false
#
# SCIM provisioning: a tenantAdmin mints a per-tenant bearer token from the admin
# UI; only its hash is stored. The IdP calls /api/scim/v2/Users with that token.
# No SCIM secret belongs in this file.

# --- AI report drafting (optional) ---
# The /report-draft endpoint generates the audit conclusions with Claude. It is
# INERT unless BOTH are set; the client then falls back to its offline,
# rule-based draft composer (no key needed for that path). Keep keys server-side
# only — never expose them to the Angular app. On Supabase set the same two with
# `supabase secrets set`.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# --- Supabase edge function (production backend) secrets ---
# Set these with `supabase secrets set` (NOT used by the Node dev server).
# APP_JWT_SECRET: dedicated secret that signs/verifies app JWTs. REQUIRED — the
#   function refuses to issue/verify tokens if unset (it no longer falls back to
#   the service-role key). Generate with `openssl rand -hex 32`.
# APP_ALLOWED_ORIGINS: comma-separated allow-list of app origins for CORS, e.g.
#   https://your-app.vercel.app,https://audit.yourdomain.com (never a wildcard).
APP_JWT_SECRET=
APP_ALLOWED_ORIGINS=
